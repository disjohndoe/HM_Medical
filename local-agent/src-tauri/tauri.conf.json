{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HM Digital Agent",
  "version": "0.1.0",
  "identifier": "hr.hmdigital.medical",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HM Digital Agent",
        "width": 400,
        "height": 300,
        "resizable": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ws://localhost:8000 wss://* http://localhost:8000 https://*"
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HM Digital Agent",
  "version": "0.12.1",
  "identifier": "hr.hmdigital.medical",
  "build": {
    "beforeBuildCommand": "pnpm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HM Digital Agent",
        "width": 400,
        "height": 340,
        "resizable": false,
        "center": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src ws://localhost:8000 wss://app.hmdigital.hr http://localhost:8000 https://app.hmdigital.hr https://localhost:8000"
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hm-agent"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFRUIzOTEwMTZDRkY5MUUKUldRZStjOFdFRG5yN2hGYi9UR2hYdHdNWUxCYUJLbDRCQjBlUWRVVkorZlpzUS9QenNqK3QwcUMK",
      "endpoints": [
        "https://github.com/disjohndoe/agent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

# ===========================================
# Production Environment Variables
# Copy to .env and fill in real values
# ===========================================
#
# Server setup (run once on fresh Hetzner CPX11):
#   fallocate -l 2G /swapfile
#   chmod 600 /swapfile && mkswap /swapfile && swapon /swapfile
#   echo '/swapfile none swap sw 0 0' >> /etc/fstab
#

# Domain - Caddy auto-provisions TLS for this FQDN
DOMAIN=app.hmdigital.hr

# Database
DB_PASSWORD=CHANGE_ME_strong_random_password

# JWT Secret - generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# CEZIH Integration (optional - defaults to mock mode)
# CEZIH_MODE=real
# CEZIH_OAUTH2_URL=https://certsso2.cezih.hr/auth/realms/CEZIH/protocol/openid-connect/token
# CEZIH_CLIENT_ID=d9fe4a5d-4ca2-4e21-8ad3-0016d78ce02f
# CEZIH_CLIENT_SECRET=
# CEZIH_FHIR_BASE_URL=https://certws2.cezih.hr:8443
# CEZIH_FHIR_AUX_URL=https://certws2.cezih.hr:9443
# CEZIH_SIGNING_URL=https://certpubws.cezih.hr
# CEZIH_SIGNING_OAUTH2_URL=https://certpubsso.cezih.hr
# CEZIH_ORG_CODE=         # HZZO sifra zdravstvene organizacije
# CEZIH_OID=              # OID informacijskog sustava (urn:oid:...)
# CEZIH_TIMEOUT=30        # Request timeout in seconds (default: 30)
# CEZIH_RETRY_ATTEMPTS=3  # Retry attempts on 5xx/401 (default: 3)

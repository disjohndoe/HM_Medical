# Application
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# Database
# IMPORTANT: Change the password! Generate with: openssl rand -hex 16
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5433/medical_mvp

# Security — REQUIRED, no default
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
